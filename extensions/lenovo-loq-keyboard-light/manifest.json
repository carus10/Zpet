{
  "id": "lenovo-loq-keyboard-light",
  "name": "Lenovo LOQ Keyboard Light",
  "version": "1.1.0",
  "description": "Controls keyboard backlight based on pet state. Working = bright, Waiting = dim, Idle = off. Supports blink transitions.",
  "main": "main.js",
  "author": "zpet",
  "requires": {
    "platform": "win32",
    "software": "Lenovo Vantage"
  },
  "settingsSchema": [
    { "key": "workingLevel",    "label": "Working Level",           "type": "select",  "options": ["Off", "Level_1", "Level_2"], "default": "Level_2" },
    { "key": "waitingLevel",    "label": "Waiting Level",           "type": "select",  "options": ["Off", "Level_1", "Level_2"], "default": "Level_1" },
    { "key": "idleLevel",       "label": "Idle Level",              "type": "select",  "options": ["Off", "Level_1", "Level_2"], "default": "Off" },
    { "key": "blinkEnabled",    "label": "Blink Enabled",           "type": "toggle",  "default": true },
    { "key": "blinkCount",      "label": "Blink Count",             "type": "number",  "min": 1, "max": 10, "default": 3 },
    { "key": "blinkOnMs",       "label": "Blink On Duration (ms)",  "type": "number",  "min": 50, "max": 2000, "default": 250 },
    { "key": "blinkOffMs",      "label": "Blink Off Duration (ms)", "type": "number",  "min": 50, "max": 2000, "default": 200 },
    { "key": "blinkFinalLevel", "label": "Level After Blink",       "type": "select",  "options": ["Off", "Level_1", "Level_2"], "default": "Off" }
  ]
}
